---
// Every <head> tag that was previously hand-rolled per page — which is exactly
// why og:/twitter:/canonical never got added to any of them.
//
// Usage:
//   <Meta title="…" description="…" path="/work/colored-air/" image={photo("…")} />
import { getImage } from "astro:assets";
import { photo } from "../lib/images.js";

const { title, description, path, image } = Astro.props;

// Clip on a word boundary. Callers pass whole opening paragraphs, and a hard
// character cut severed "Beirut" mid-word on the Colored Air card — the one
// project that is *about* Beirut. 155 also sits inside the width Google renders.
function clip(text, max = 155) {
  const s = String(text).trim();
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const lastSpace = cut.lastIndexOf(" ");
  return (
    (lastSpace > 0 ? cut.slice(0, lastSpace) : cut).replace(/[\s,;:.—–-]+$/, "") + "…"
  );
}

const summary = clip(description);

const canonical = new URL(path, Astro.site).href;

// Pages with no image of their own (the essays) still deserve a preview rather
// than a bare text stub when shared.
const source = image ?? photo("colored-air/HS-ColoredAir-2025-01.JPG");

// Social scrapers do not decode avif or webp, so the preview is always a JPEG.
// Crop to 1200x630 — the aspect every platform expects. Left at native height a
// portrait frame becomes a 1200x1800, 640KB file that WhatsApp and iMessage drop
// outright and that Twitter/LinkedIn centre-crop unpredictably.
const generated = await getImage({
  src: source,
  format: "jpeg",
  width: 1200,
  height: 630,
  fit: "cover",
  position: "center",
  quality: 78,
});
const ogImage = new URL(generated.src, Astro.site).href;
---

<title>{title}</title>
<meta name="description" content={summary} />

{/* Icons live here rather than in nine hand-copied <head> blocks — the same
    duplication that kept og: tags off the site for so long. The .ico is only
    for browsers that ask for it unprompted; the SVG is what everything modern
    uses, and it inverts itself in a dark tab bar. */}
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" type="image/x-icon" href="/favicon.ico" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="canonical" href={canonical} />

<meta property="og:type" content="website" />
<meta property="og:site_name" content="Habib Saleh" />
<meta property="og:title" content={title} />
<meta property="og:description" content={summary} />
<meta property="og:url" content={canonical} />
<meta property="og:image" content={ogImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />

<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={summary} />
<meta name="twitter:image" content={ogImage} />
