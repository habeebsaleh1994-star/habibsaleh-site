---
// The running head. Two cells, in the same order and relationship as the home
// page's .masthead — the name, then the four sections — one step down in scale.
// Replaces .about-header, .work-header, .editorial-header, .writing-header and
// .project-header, which were the same twelve declarations written out five
// times and had already drifted apart.
//
// `here` is the section whose own landing page this is: /work/, /editorial/,
// /writing/, /about/. Only those four pass it, and there the word stops being a
// link because it would point at the page you are reading. A leaf page — a
// project, a story, an essay — passes nothing: there the section word is the way
// *up*, so it stays a link, and nothing on the page is marked. That is
// deliberate. Above a photograph, no word should darken.
const { here = null } = Astro.props;

const SECTIONS = ["work", "editorial", "writing", "about"];
---

<header class="site-header">
  <a class="signature" href="/">Habib Saleh</a>
  <nav class="site-nav" aria-label="Sections">
    {SECTIONS.map((name) =>
      name === here
        ? <span aria-current="page">{name}</span>
        : <a href={`/${name}/`}>{name}</a>,
    )}
  </nav>
</header>
