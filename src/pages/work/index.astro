---
import { Picture } from "astro:assets";
import "../../styles/global.css";
import "../../styles/work.css";
import Meta from "../../components/Meta.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { photo } from "../../lib/images.js";

// Same glob as [slug].astro, so this index can only ever list a project that
// actually has a page. Glob order is by directory name.
const projectModules = import.meta.glob("../../content/work/*/project.json", { eager: true });

const projects = Object.entries(projectModules).map(([path, mod]) => {
  const project = mod.default || mod;
  const slug = path.split("/").slice(-2, -1)[0];
  // Season of the Mulberry has no `cover` key, so fall back to the first photo —
  // which may be a bare filename or a { file, alt } object.
  const first = project.photos[0];
  const cover = project.cover || (typeof first === "string" ? first : first.file);
  return { project, slug, cover };
});
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Meta
      title="Work — Habib Saleh"
      description="Long-form documentary photography projects by Habib Saleh, made in Lebanon."
      path="/work/"
      image={photo(projects[0].slug + "/" + projects[0].cover)}
    />
  </head>
  <body>
    <div class="work-page">

      <SiteHeader here="work" />

      <main class="work-index">
        <p class="work-index-title">
          Long-form documentary work.
        </p>

        <div class="grid">
          {projects.map(({ project, slug, cover }) => (
            <a class="tile" href={`/work/${slug}/`}>
              <div class="thumb thumb-image">
                <Picture
                  src={photo(`${slug}/${cover}`)}
                  alt={project.title}
                  formats={["avif", "webp"]}
                  fallbackFormat="jpeg"
                  widths={[450, 700, 900, 1200]}
                  sizes="(max-width: 640px) 100vw, 446px"
                  loading="lazy"
                  decoding="async"
                />
              </div>
              <div class="meta">
                <span class="meta-type">
                  {project.type}{project.year ? ` · ${project.year}` : ""}
                </span>
                <span class="meta-title">{project.title}</span>
              </div>
            </a>
          ))}
        </div>
      
        <footer class="footer">
          <span>© Habib Saleh</span>
          <a class="footer-mail" href="mailto:contact@habibsaleh.com">contact@habibsaleh.com</a>
        </footer>
      </main>

    </div>
  </body>
</html>
