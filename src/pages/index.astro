---
// The threshold — the book's half-title, and the only page that is not itself
// part of the work.
import Book from "../layouts/Book.astro";
import BookFoot from "../components/BookFoot.astro";
import { photo } from "../lib/images.js";
import book from "../content/book/book.json";
import { manuscript } from "../lib/manuscript.js";

const { leaves } = manuscript();
const firstLeaf = leaves[0].path;
---

<Book
  title="Habib Saleh"
  description={`${book.title} — ${book.subtitle} Photographs and writing by Habib Saleh, made in Lebanon.`}
  path="/"
  image={photo("colored-air/HS-ColoredAir-2025-01.JPG")}
  screen="threshold"
>
  <div class="head">
    <span class="wordmark">Habib Saleh</span>
    <span class="wordmark edition">{book.edition}</span>
  </div>

  <section class="threshold-body">
    <h1 class="work-title">{book.title}</h1>
    <p class="work-subtitle">{book.subtitle}</p>

    <div class="doors">
      <a class="door" href="/prelude/">Begin the work →</a>
      {/* Revealed by the script below only when a bookmark exists, so a
          first-time reader is never offered a place to resume. */}
      <a class="door-small" id="resume" href={firstLeaf} hidden>Continue reading</a>
      <a class="door-small" href="/contents/">Contents</a>
    </div>
  </section>

  <BookFoot />
</Book>

<script>
  // The bookmark is a leaf's address rather than its number: an address is
  // built from the leaf's own content, so inserting a photograph ahead of it
  // never moves anyone's place in the book.
  const resume = document.getElementById("resume");
  try {
    const saved = window.localStorage.getItem("tp:leaf");
    if (resume && saved && saved.startsWith("/read/")) {
      resume.setAttribute("href", saved);
      resume.hidden = false;
    }
  } catch (e) {
    /* private mode — the offer simply never appears */
  }
</script>
