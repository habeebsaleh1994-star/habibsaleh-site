---
import { Picture } from "astro:assets";
import "../styles/global.css";
import Meta from "../components/Meta.astro";
import { photo } from "../lib/images.js";

const featuredProjects = [
  {
    title: "Colored Air",
    type: "Documentary",
    year: "2023 — Ongoing",
    slug: "colored-air",
    cover: "colored-air/HS-ColoredAir-2025-01.JPG",
  },
  {
    title: "Before It Disappears",
    type: "Documentary",
    year: "2023 — 2025",
    slug: "before-it-disappears",
    cover: "before-it-disappears/before-it-disappears-01.jpg",
  },
  {
    title: "The Season of the Mulberry",
    type: "Documentary",
    year: "2025",
    slug: "season-of-the-mulberry",
    cover: "season-of-the-mulberry/HS-TheSeasonOfTheMulberry-2025-01.JPG",
  },
  {
    title: "When Roses Bloom",
    type: "Documentary",
    year: "",
    slug: "when-roses-bloom",
    color: "linear-gradient(140deg, #a89684 0%, #7a6852 50%, #4d3f2f 100%)",
  },
];

const recentWriting = [
  { title: "More Sweet Than Bitter", date: "Oct 2025", slug: "more-sweet-than-bitter" },
  { title: "The Unfinished God", date: "Sep 2025", slug: "the-unfinished-god" },
];

// Which projects actually have a page? work/[slug].astro builds its routes from
// this same glob, so a tile can never link to a route that was not generated —
// and a forthcoming project becomes a link the moment its content dir appears.
const workModules = import.meta.glob("../content/work/*/project.json", { eager: true });
const publishedSlugs = new Set(
  Object.keys(workModules).map((path) => path.split("/").slice(-2, -1)[0]),
);
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Meta
      title="Habib Saleh"
      description="A photographer's record of light, slow disappearance, and the irreplaceable ordinary. Documentary, editorial and portrait work from Lebanon."
      path="/"
      image={photo("colored-air/HS-ColoredAir-2025-01.JPG")}
    />
  </head>
  <body>
    <main class="page">
      <header class="masthead">
        <div class="name">Habib Saleh</div>
        <nav class="nav">
          <a href="/work/">work</a>
          <a href="/editorial/">editorial</a>
          <a href="/writing/">writing</a>
          <a href="/about/">about</a>
        </nav>
      </header>

      <section class="intro">
        <p class="lede">A record of light.<br/>A record of the strangeness of being alive.</p>
      </section>

      <section class="grid">
        {featuredProjects.map((project) => {
          const published = publishedSlugs.has(project.slug);
          const Tile = published ? "a" : "div";
          return (
            <Tile class="tile" href={published ? `/work/${project.slug}/` : undefined}>
              {project.cover ? (
                <div class="thumb thumb-image">
                  <Picture
                    src={photo(project.cover)}
                    {/* Astro strips alt="" from the output, leaving no alt attribute at
                        all — worse than the title being announced twice. */}
                    alt={project.title}
                    formats={["avif", "webp"]}
                    fallbackFormat="jpeg"
                    widths={[450, 700, 900, 1200]}
                    sizes="(max-width: 640px) 100vw, 446px"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
              ) : (
                <div class="thumb" style={`background: ${project.color};`}></div>
              )}
              <div class="meta">
                <span class="meta-type">
                  {project.type}
                  {published ? (project.year ? ` · ${project.year}` : "") : " · Forthcoming"}
                </span>
                <span class="meta-title">{project.title}</span>
              </div>
            </Tile>
          );
        })}
      </section>

      <section class="writing">
        <header class="writing-head">
          <span class="writing-title">Recent writing</span>
          <a class="writing-all" href="/writing/">all writing →</a>
        </header>
        <ul class="writing-list">
          {recentWriting.map((piece) => (
            <li>
              <a href={`/writing/${piece.slug}/`}>
                <span class="piece-date">{piece.date}</span>
                <span class="piece-title">{piece.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </section>

      <footer class="footer">
        <span>© Habib Saleh</span>
      </footer>
    </main>
  </body>
</html>
