---
import { Picture } from "astro:assets";
import "../../styles/global.css";
import "../../styles/editorial.css";
import Meta from "../../components/Meta.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import { photo } from "../../lib/images.js";

// Same glob pattern as the writing index. Files prefixed with "_" are templates,
// not published stories, so they're filtered out of the build.
const storyModules = import.meta.glob("../../content/editorial/*.json", { eager: true });
const stories = Object.entries(storyModules)
  .filter(([path]) => !path.split("/").pop().startsWith("_"))
  .map(([, m]) => m.default || m)
  .sort((a, b) => (a.dateSort < b.dateSort ? 1 : -1)); // newest first
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Meta
      title="Editorial — Habib Saleh"
      description="Commissioned fashion, editorial, and portrait photography by Habib Saleh."
      path="/editorial/"
      image={stories.length ? photo("editorial/" + stories[0].slug + "/" + stories[0].cover) : undefined}
    />
  </head>
  <body>
    <div class="editorial-page">

      <SiteHeader here="editorial" />

      <main class="editorial-index">
        <p class="editorial-index-title">
          Commissioned fashion, editorial, and portrait work.
        </p>

        {stories.length === 0 ? (
          <p class="editorial-empty">Selected stories, coming shortly.</p>
        ) : (
          <div class="editorial-grid">
            {stories.map((story) => (
              <a class="editorial-tile" href={`/editorial/${story.slug}/`}>
                <div class="editorial-thumb">
                  <Picture
                    src={photo(`editorial/${story.slug}/${story.cover}`)}
                    alt={story.title}
                    formats={["avif"]}
                    fallbackFormat="jpeg"
                    widths={[340, 680, 800]}
                    sizes="(max-width: 640px) 100vw, (max-width: 900px) 45vw, 330px"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="editorial-tile-meta">
                  <span class="editorial-tile-client">
                    {/* Where the brand *is* the story name, showing both would
                        print the same words twice, one line apart. */}
                    {[story.client === story.title ? "" : story.client, story.year]
                      .filter(Boolean)
                      .join(" · ")}
                  </span>
                  <span class="editorial-tile-title">{story.title}</span>
                </div>
              </a>
            ))}
          </div>
        )}

        <footer class="footer">
          <span>© Habib Saleh</span>
          <a class="footer-mail" href="mailto:contact@habibsaleh.com">contact@habibsaleh.com</a>
        </footer>
      </main>

    </div>
  </body>
</html>
