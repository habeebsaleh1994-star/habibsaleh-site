---
import Meta from "../../components/Meta.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import "../../styles/global.css";
import "../../styles/writing.css";

// getStaticPaths tells Astro to generate one page per writing piece at build time.
export async function getStaticPaths() {
  const pieceModules = import.meta.glob("../../content/writing/*.json", { eager: true });
  const pieces = Object.values(pieceModules).map((m) => m.default || m);

  return pieces.map((piece) => ({
    params: { slug: piece.slug },
    props: { piece },
  }));
}

const { piece } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <Meta
      title={`${piece.title} — Habib Saleh`}
      description={piece.paragraphs[0]}
      path={`/writing/${piece.slug}/`}
    />
  </head>
  <body>
    <div class="writing-page">

      <SiteHeader />

      <article class="piece">
        <header class="piece-header">
          <div class="piece-meta">{piece.date}</div>
          <h1>{piece.title}</h1>
        </header>

        <div class="piece-body">
          {piece.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
        </div>

        <footer class="footer">
        <a href="/writing/">← all writing</a>
        <a class="footer-mail" href="mailto:contact@habibsaleh.com">contact@habibsaleh.com</a>
      </footer>
      </article>

    </div>
  </body>
</html>
