    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Not in this book — Habib Saleh</title>
    <meta name="robots" content="noindex" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg?v=2" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico?v=2" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png?v=2" />
  </head>
  <body>
    <div class="book prelude rises">
      <div class="head">
        <a class="wordmark" href="/">Habib Saleh</a>
        <span class="head-label">Not found</span>
      </div>

      <main class="prelude-body">
        <p class="prelude-opening">This leaf is not in the book.</p>
